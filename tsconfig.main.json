{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "types": ["node", "electron"]
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "src/utils/**/*",
    "src/types/**/*",
    "src/workers/**/*",
    "src/services/**/*"
  ],
  "exclude": [
    "src/renderer/**/*",
    "src/preload/**/*",
    "src/**/__tests__/**/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "tests/**/*",
    "node_modules",
    "dist",
    "build"
  ]
}