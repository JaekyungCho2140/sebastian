{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "electron"]
  },
  "include": [
    "src/preload/**/*"
  ],
  "exclude": [
    "src/main/**/*",
    "src/renderer/**/*",
    "node_modules",
    "dist",
    "build"
  ]
}