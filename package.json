{
  "dependencies": {
    "electron-store": "^10.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "task-master-ai": "^0.19.0"
  },
  "name": "sebastian",
  "version": "0.1.11",
  "description": "Sebastian Electron-Vite-React Demo Application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:clean && npm run build:renderer && npm run build:main && npm run build:preload",
    "build:clean": "rimraf dist",
    "build:renderer": "vite build",
    "build:main": "tsc --project tsconfig.main.json",
    "build:preload": "tsc --target es2020 --module es2020 --outDir dist/preload --moduleResolution node --esModuleInterop --skipLibCheck src/preload/index.ts",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win-msi": "npm run build && electron-builder --win --x64",
    "dist:win-portable": "npm run build && electron-builder --win --portable",
    "pack": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release": "npm run version:patch && git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaekyungCho2140/sebastian.git"
  },
  "keywords": [],
  "author": "Jaekyung Cho",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JaekyungCho2140/sebastian/issues"
  },
  "homepage": "https://github.com/JaekyungCho2140/sebastian#readme",
  "devDependencies": {
    "@types/electron-store": "^1.3.1",
    "@types/node": "^24.0.12",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.3"
  },
  "build": {
    "appId": "com.sebastian.app",
    "productName": "Sebastian",
    "copyright": "Copyright © 2025 Jaekyung Cho",
    "icon": "src/assets/icons/icon.ico",
    "asar": true,
    "electronUpdaterCompatibility": ">=2.16",
    "nativeRebuilder": "sequential",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/electron-store/**/*",
      "node_modules/conf/**/*",
      "node_modules/env-paths/**/*",
      "node_modules/pkg-up/**/*",
      "node_modules/write-file-atomic/**/*",
      "node_modules/find-up/**/*",
      "node_modules/locate-path/**/*",
      "node_modules/path-exists/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sebastian",
      "warningsAsErrors": false,
      "upgradeCode": "757E765C-C1E3-40E3-841E-2ADD52310561",
      "additionalWixArgs": []
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sebastian"
    }
  }
}
